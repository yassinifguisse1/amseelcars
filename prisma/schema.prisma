// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model BlogArticle {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String
  locale      String   @default("fr")
  translationGroup String?
  title       String
  content     String
  category    String
  readTime    String
  date        String
  publishedAt DateTime
  image       String
  imageMetaTitle String?
  altText     String
  caption     String
  imageDescription String?
  description String
  featured    Boolean  @default(false)
  indexable   Boolean  @default(true)
  tags        String[]
  author      Json     // { name, avatar, bio }
  seo         Json     // { metaTitle, metaDescription, keywords, canonical }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String   // Clerk user ID
  
  @@index([category])
  @@index([publishedAt])
  @@index([translationGroup])
  @@unique([slug, locale])
  @@map("blog_articles")
}

model BlogMediaAsset {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  url         String
  fileName    String?
  folderId    String?  @db.ObjectId
  folderName  String?
  metadata    Json     // { fr|en|es|de|pl: { metaTitle, altText, caption, description } }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String   // Clerk user ID

  @@index([folderId])
  @@index([createdAt])
  @@map("blog_media_assets")
}

model BlogMediaFolder {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  articleSlug String?
  translationGroup String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String   // Clerk user ID

  @@index([articleSlug])
  @@index([translationGroup])
  @@map("blog_media_folders")
}

model Page {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  content     String
  description String
  image       String?
  altText     String?
  published   Boolean  @default(false)
  indexable   Boolean  @default(true)
  seo         Json     // { metaTitle, metaDescription, keywords, canonical }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String   // Clerk user ID
  
  @@index([published])
  @@map("pages")
}
